## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.sln.docstates

# Release files
bin/

# LifeSim artifacts folder
artifacts/

# Save files
saves/

# LifeSim Backend config file
backend.txt

# Code Coverage
coveragereport/

# Include Wavefront .obj files
!content/**/*.obj
!res/**/*.obj

# Trace files
*.nettrace
*.speedscope.json

# Game development documentation notes
# I have a private repo for this, but I normally have a copy here for quick access
# and I don't want to commit it by accident.
gdd.md
